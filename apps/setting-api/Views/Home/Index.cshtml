@{
    ViewData["Title"] = "Home";
    var isAuthenticated = Context.Session.GetString("IsAuthenticated") == "true";
}

<div class="row">
    <div class="col-12">
        <div class="jumbotron bg-light p-5 rounded">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="display-4">Lab Portal</h1>
                    <p class="lead">Welcome to the Lab portal. Access application settings and Azure login credentials.</p>
                </div>
                <div class="text-end">
                    @if (isAuthenticated)
                    {
                        <div class="badge bg-success fs-6 mb-2">
                            <i class="fas fa-check-circle"></i> Authenticated
                        </div>
                        <br />
                        <a href="@Url.Action("Logout", "Home")" class="btn btn-outline-secondary btn-sm">
                            <i class="fas fa-sign-out-alt"></i> Logout
                        </a>
                    }
                    else
                    {
                        <div class="badge bg-warning fs-6 mb-2">
                            <i class="fas fa-lock"></i> Not Authenticated
                        </div>
                        <br />
                        <a href="@Url.Action("Login", "Home")" class="btn btn-primary btn-sm">
                            <i class="fas fa-sign-in-alt"></i> Login
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">
                    <i class="fas fa-cog"></i> Application Settings
                </h5>
            </div>
            <div class="card-body">
                <p class="card-text">View and manage all application configuration settings organized by category.</p>
                <ul class="list-unstyled">
                    <li><i class="fas fa-check text-success"></i> View all settings by category</li>
                    <li><i class="fas fa-check text-success"></i> Copy values to clipboard</li>
                    <li><i class="fas fa-check text-success"></i> API endpoint documentation</li>
                </ul>
            </div>
            <div class="card-footer">
                @if (isAuthenticated)
                {
                    <a href="@Url.Action("Settings", "Home")" class="btn btn-primary">
                        <i class="fas fa-arrow-right"></i> Go to Settings
                    </a>
                }
                else
                {
                    <a href="@Url.Action("Login", "Home")" class="btn btn-outline-primary">
                        <i class="fas fa-lock"></i> Login Required
                    </a>
                }
            </div>
        </div>
    </div>
    
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0">
                    <i class="fas fa-key"></i> Azure Login Assignment
                </h5>
            </div>
            <div class="card-body">
                <p class="card-text">Claim Azure login credentials for your development session.</p>
                <ul class="list-unstyled">
                    <li><i class="fas fa-check text-success"></i> Claim available login credentials</li>
                    <li><i class="fas fa-check text-success"></i> View all login entries</li>
                    <li><i class="fas fa-check text-success"></i> Track claimed credentials</li>
                </ul>
            </div>
            <div class="card-footer">
                @if (isAuthenticated)
                {
                    <a href="@Url.Action("AzureLogin", "Home")" class="btn btn-info">
                        <i class="fas fa-arrow-right"></i> Go to Azure Login
                    </a>
                }
                else
                {
                    <a href="@Url.Action("Login", "Home")" class="btn btn-outline-info">
                        <i class="fas fa-lock"></i> Login Required
                    </a>
                }
            </div>
        </div>
    </div>
</div>
