@{
    ViewData["Title"] = "Home";
}

<div class="row">
    <div class="col-12">
        <div class="jumbotron bg-light p-5 rounded">
            <h1 class="display-4">Configuration API Portal</h1>
            <p class="lead">Welcome to the Configuration API management portal. Access application settings and Azure login credentials.</p>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">
                    <i class="fas fa-cog"></i> Application Settings
                </h5>
            </div>
            <div class="card-body">
                <p class="card-text">View and manage all application configuration settings organized by category.</p>
                <ul class="list-unstyled">
                    <li><i class="fas fa-check text-success"></i> View all settings by category</li>
                    <li><i class="fas fa-check text-success"></i> Copy values to clipboard</li>
                    <li><i class="fas fa-check text-success"></i> API endpoint documentation</li>
                </ul>
            </div>
            <div class="card-footer">
                <a href="@Url.Action("Settings", "Home")" class="btn btn-primary">
                    <i class="fas fa-arrow-right"></i> Go to Settings
                </a>
            </div>
        </div>
    </div>
    
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0">
                    <i class="fas fa-key"></i> Azure Login Assignment
                </h5>
            </div>
            <div class="card-body">
                <p class="card-text">Claim Azure login credentials for your development session.</p>
                <ul class="list-unstyled">
                    <li><i class="fas fa-check text-success"></i> Claim available login credentials</li>
                    <li><i class="fas fa-check text-success"></i> View all login entries</li>
                    <li><i class="fas fa-check text-success"></i> Track claimed credentials</li>
                </ul>
            </div>
            <div class="card-footer">
                <a href="@Url.Action("AzureLogin", "Home")" class="btn btn-info">
                    <i class="fas fa-arrow-right"></i> Go to Azure Login
                </a>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h5><i class="fas fa-info-circle"></i> Quick Links</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4">
                        <h6>API Endpoints</h6>
                        <ul class="list-unstyled">
                            <li><a href="/api/configuration/all" class="text-decoration-none">
                                <i class="fas fa-link"></i> /api/configuration/all
                            </a></li>
                            <li><a href="/api/configuration/health" class="text-decoration-none">
                                <i class="fas fa-link"></i> /api/configuration/health
                            </a></li>
                        </ul>
                    </div>
                    <div class="col-md-4">
                        <h6>Documentation</h6>
                        <ul class="list-unstyled">
                            <li><a href="/swagger" class="text-decoration-none">
                                <i class="fas fa-book"></i> API Documentation
                            </a></li>
                        </ul>
                    </div>
                    <div class="col-md-4">
                        <h6>Status</h6>
                        <p class="text-success mb-0">
                            <i class="fas fa-circle"></i> Service Online
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
