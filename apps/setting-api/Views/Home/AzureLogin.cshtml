@model ConfigApi.Models.AzureLoginViewModel

@{
    ViewData["Title"] = "Azure Login Assignment";
}

<div class="row">
    <div class="col-12">
        <h1>Azure Login Assignment</h1>
        <p class="text-muted">Claim an Azure login credential for your session</p>
    </div>
</div>

@if (Model.AssignedLogin != null)
{
    <div class="row mb-4">
        <div class="col-12">
            <div class="alert alert-success">
                <h4><i class="fas fa-check-circle"></i> Login Assigned Successfully!</h4>
                <p>Your Azure login credentials have been assigned:</p>
                <div class="card">
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <strong>Email:</strong>
                                <div class="input-group mb-2">
                                    <input type="text" class="form-control" value="@Model.AssignedLogin.LoginEmail" readonly>
                                    <button class="btn btn-outline-secondary" type="button" onclick="copyToClipboard('@Model.AssignedLogin.LoginEmail')">
                                        <i class="fas fa-copy"></i>
                                    </button>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <strong>Password:</strong>
                                <div class="input-group mb-2">
                                    <input type="password" id="assignedPassword" class="form-control" value="@Model.AssignedLogin.LoginPassword" readonly>
                                    <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('assignedPassword')">
                                        <i class="fas fa-eye" id="assignedPasswordIcon"></i>
                                    </button>
                                    <button class="btn btn-outline-secondary" type="button" onclick="copyToClipboard('@Model.AssignedLogin.LoginPassword')">
                                        <i class="fas fa-copy"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                        <p class="text-muted mb-0"><strong>Claimed by:</strong> @Model.AssignedLogin.ClaimedBy</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
else if (!string.IsNullOrEmpty(Model.ClaimedByName))
{
    <div class="row mb-4">
        <div class="col-12">
            <div class="alert alert-warning">
                <h4><i class="fas fa-exclamation-triangle"></i> No Available Logins</h4>
                <p>Sorry, all login credentials have been claimed. Please contact the administrator.</p>
            </div>
        </div>
    </div>
}

@if (!ViewData.ModelState.IsValid)
{
    <div class="row mb-4">
        <div class="col-12">
            <div class="alert alert-danger">
                <h4><i class="fas fa-exclamation-circle"></i> Error</h4>
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <p class="mb-1">@error.ErrorMessage</p>
                }
            </div>
        </div>
    </div>
}

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5><i class="fas fa-user-plus"></i> Claim a Login</h5>
            </div>
            <div class="card-body">
                <form method="post" id="claimLoginForm">
                    <div class="mb-3">
                        <label for="claimedByName" class="form-label">Your Name</label>
                        <input type="text" class="form-control" id="claimedByName" name="claimedByName" 
                               value="@Model.ClaimedByName" placeholder="Enter your name" required>
                        @if (ViewData.ModelState["ClaimedByName"]?.Errors.Any() == true)
                        {
                            <div class="text-danger">
                                @ViewData.ModelState["ClaimedByName"]?.Errors.First().ErrorMessage
                            </div>
                        }
                    </div>
                    <button type="submit" class="btn btn-primary" id="claimLoginBtn">
                        <i class="fas fa-key"></i> Claim Login
                    </button>
                </form>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5><i class="fas fa-info-circle"></i> Available Logins</h5>
            </div>
            <div class="card-body">
                @{
                    var availableLogins = Model.LoginEntries.Where(l => string.IsNullOrEmpty(l.ClaimedBy)).ToList();
                }
                <p><strong>Available:</strong> @availableLogins.Count</p>
                <p><strong>Total:</strong> @Model.LoginEntries.Count</p>
                
                @if (availableLogins.Any())
                {
                    <div class="text-success">
                        <i class="fas fa-check"></i> Logins are available for claiming
                    </div>
                }
                else
                {
                    <div class="text-danger">
                        <i class="fas fa-times"></i> No logins available
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h5><i class="fas fa-list"></i> Claimed Login Entries</h5>
            </div>
            <div class="card-body">
                @{
                    var claimedLogins = Model.LoginEntries.Where(l => !string.IsNullOrEmpty(l.ClaimedBy)).ToList();
                }
                @if (claimedLogins.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th>Email</th>
                                    <th>Password</th>
                                    <th>Claimed By</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var login in claimedLogins)
                                {
                                    <tr class="table-secondary">
                                        <td>
                                            <code>@login.LoginEmail</code>
                                            <button class="btn btn-sm btn-outline-secondary ms-2" onclick="copyToClipboard('@login.LoginEmail')" title="Copy email">
                                                <i class="fas fa-copy"></i>
                                            </button>
                                        </td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <input type="password" id="pwd_@(claimedLogins.IndexOf(login))" class="form-control form-control-sm" 
                                                       value="@login.LoginPassword" readonly style="width: 150px;">
                                                <button class="btn btn-sm btn-outline-secondary ms-1" 
                                                        onclick="togglePassword('pwd_@(claimedLogins.IndexOf(login))')" title="Show/Hide password">
                                                    <i class="fas fa-eye" id="pwd_@(claimedLogins.IndexOf(login))_icon"></i>
                                                </button>
                                                <button class="btn btn-sm btn-outline-secondary ms-1" 
                                                        onclick="copyToClipboard('@login.LoginPassword')" title="Copy password">
                                                    <i class="fas fa-copy"></i>
                                                </button>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="text-muted">@login.ClaimedBy</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="alert alert-info">
                        <h5>No Claimed Login Entries</h5>
                        <p>No login credentials have been claimed yet. Use the form above to claim a credential.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<script>
function copyToClipboard(text) {
    navigator.clipboard.writeText(text).then(function() {
        // Could add a toast notification here
        console.log('Copied to clipboard:', text);
    }).catch(function(err) {
        console.error('Failed to copy text: ', err);
        alert('Failed to copy to clipboard');
    });
}

function togglePassword(inputId) {
    const input = document.getElementById(inputId);
    const icon = document.getElementById(inputId + '_icon') || document.getElementById(inputId.replace('pwd_', '') + 'PasswordIcon');
    
    if (input.type === 'password') {
        input.type = 'text';
        if (icon) icon.className = 'fas fa-eye-slash';
    } else {
        input.type = 'password';
        if (icon) icon.className = 'fas fa-eye';
    }
}

// Add confirmation dialog for claiming login
document.addEventListener('DOMContentLoaded', function() {
    const claimForm = document.getElementById('claimLoginForm');
    const claimBtn = document.getElementById('claimLoginBtn');
    
    if (claimForm) {
        claimForm.addEventListener('submit', function(e) {
            e.preventDefault();
            
            const nameInput = document.getElementById('claimedByName');
            const userName = nameInput.value.trim();
            
            if (!userName) {
                alert('Please enter your name before claiming a login.');
                nameInput.focus();
                return;
            }
            
            // Show confirmation dialog
            const confirmMessage = `Are you sure you want to claim a login credential for "${userName}"?\n\nOnce claimed, this cannot be undone and the credential will be assigned exclusively to you.`;
            
            if (confirm(confirmMessage)) {
                // Disable the button to prevent double submission
                claimBtn.disabled = true;
                claimBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Claiming...';
                
                // Submit the form
                this.submit();
            }
        });
        
        // Re-enable button if user navigates back to page
        window.addEventListener('pageshow', function(event) {
            if (event.persisted || (window.performance && window.performance.navigation.type === 2)) {
                // Page was loaded from cache (back/forward button)
                claimBtn.disabled = false;
                claimBtn.innerHTML = '<i class="fas fa-key"></i> Claim Login';
            }
        });
    }
});
</script>