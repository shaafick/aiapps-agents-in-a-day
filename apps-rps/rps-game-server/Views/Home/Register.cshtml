@{
    ViewData["Title"] = "Register Player";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <h2 class="mb-3">Register New Player</h2>

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">@TempData["Error"]</div>
            }

            @if (ViewBag.Success == true)
            {
                <div class="alert alert-success">
                    <strong>Registered!</strong>
                    <div>Player ID: @ViewBag.PlayerId</div>
                    <div>Player Name: @ViewBag.PlayerName</div>
                    <div>@ViewBag.Message</div>
                </div>
            }

            <form asp-action="Register" method="post">
                <div class="mb-3">
                    <label for="playerName" class="form-label">Player Name</label>
                    <input type="text" class="form-control" id="playerName" name="playerName" placeholder="Enter player name" />
                </div>

                <button type="submit" class="btn btn-primary">Register</button>
                <a href="/Home/TournamentWaiting" class="btn btn-link">Back to Lobby</a>
            </form>
        </div>
    </div>
</div>
